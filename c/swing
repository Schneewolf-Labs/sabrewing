#!/usr/bin/env python3
"""sabrewing — trillion-parameter models on hardware you own.

  swing run "prompt" [-n N]    one-shot generation
  swing api [args...]          OpenAI-compatible API + web UI (port 8000)
  swing warm <prompts.txt>     build expert-usage history (one prompt/line)
  swing build [cuda]           build the engine (cuda = GPU resident tier)
  swing info                   model, cache-history and hardware status

Environment:
  SWING_MODEL=<dir>   model snapshot (also honors COLI_MODEL)
  Engine knobs pass through: PIN, PIN_N, USAGE_SAVE, NOGPU, GPU_DEV, IDOT

sabrewing is a fork of colibrì; the GLM-5.2 engine remains available
through the original `coli` launcher alongside this one.
"""
import os
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent


def model_dir():
    m = os.environ.get("SWING_MODEL") or os.environ.get("COLI_MODEL")
    if not m:
        sys.exit("set SWING_MODEL=<snapshot dir> (converted Inkling weights)")
    return m


def engine():
    exe = HERE / "inkling"
    if not exe.exists():
        sys.exit("engine not built: run `swing build` (or `swing build cuda`)")
    return str(exe)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        return
    cmd, args = sys.argv[1], sys.argv[2:]

    if cmd == "build":
        make = ["make", "-C", str(HERE), "inkling"]
        if args and args[0] == "cuda":
            make.append("CUDA=1")
        sys.exit(subprocess.call(make))

    if cmd == "run":
        if not args:
            sys.exit('usage: swing run "prompt" [-n N]')
        env = dict(os.environ, SNAP=model_dir())
        sys.exit(subprocess.call([engine(), "-p", args[0], *args[1:]], env=env))

    if cmd == "warm":
        if not args:
            sys.exit("usage: swing warm <prompts.txt>")
        env = dict(os.environ, SNAP=model_dir())
        sys.exit(subprocess.call([engine(), "-f", args[0], "-n", "32"], env=env))

    if cmd == "api":
        sys.exit(subprocess.call([sys.executable, str(HERE / "openai_server.py"),
                                  "--engine", engine(), "--model", model_dir(),
                                  "--cap", "0", *args]))

    if cmd == "info":
        m = model_dir()
        size = sum(f.stat().st_size for f in Path(m).glob("*.safetensors")) / 1e9
        usage = Path(m) / ".coli_usage"
        print(f"model:   {m}  ({size:.0f} GB)")
        print(f"history: {'%d KB' % (usage.stat().st_size // 1024) if usage.exists() else 'none (run `swing warm`)'}")
        print(f"engine:  {'built' if (HERE / 'inkling').exists() else 'not built'}")
        try:
            gpu = subprocess.run(["nvidia-smi", "--query-gpu=name,memory.total",
                                  "--format=csv,noheader"], capture_output=True, text=True, timeout=5)
            print(f"gpu:     {gpu.stdout.strip() or 'none'}")
        except (FileNotFoundError, subprocess.TimeoutExpired):
            print("gpu:     none")
        return

    sys.exit(f"unknown command: {cmd}\n\n{__doc__.strip()}")


if __name__ == "__main__":
    main()
